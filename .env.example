# =============================================
# Portfolio — Variáveis de Ambiente
# Copie este arquivo para .env e preencha
# =============================================

# OpenWeather API (free tier suficiente)
# Obtenha em: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# PostgreSQL (NPS Database)
POSTGRES_PASSWORD=nps_secret_2025

# JWT — API Gateway
# Gere um secret forte: openssl rand -base64 32
JWT_SECRET=change_this_to_a_strong_random_secret_min_32_chars

# Admin credentials — acesso às rotas protegidas do gateway
ADMIN_USER=admin
ADMIN_PASS=admin2025
