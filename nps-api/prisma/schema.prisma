generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model NpsResponse {
  id        String   @id @default(cuid())
  score     Int
  comment   String?
  name      String?
  page      String   @default("portfolio")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([page])
  @@index([score])
  @@index([createdAt])
}
