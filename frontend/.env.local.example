# ─── Com Docker (tudo via Nginx na porta 80) ──────────────────
NEXT_PUBLIC_WEATHER_API_URL=/api/weather
NEXT_PUBLIC_NPS_API_URL=/api/nps
# GATEWAY_URL não é necessário no Docker (Next.js usa rewrite via Nginx)
NEXT_PUBLIC_OPENWEATHER_API_KEY=your_openweather_api_key_here

# ─── Desenvolvimento local sem Docker ─────────────────────────
# NEXT_PUBLIC_WEATHER_API_URL=/api/weather
# NEXT_PUBLIC_NPS_API_URL=/api/nps
# GATEWAY_URL=http://localhost:4000
